    "start": "next start",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix && prettier --write .",
    "lint:strict": "eslint --max-warnings=0 src",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "db:setup": "node scripts/setup-appwrite-db.mjs",
    "build:widget": "node scripts/build-widget.mjs",
    "build:sdk": "npm run build -w packages/widget-sdk",
