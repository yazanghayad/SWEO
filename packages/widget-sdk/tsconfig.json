{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["DOM", "ES2020"],
    "strict": true,
    "declaration": true,
    "declarationDir": "dist/types",
    "outDir": "dist",
    "esModuleInterop": true,
    "jsx": "react-jsx",
    "skipLibCheck": true,
    "rootDir": "src"
  },
  "include": ["src/**/*.ts"]
}
